FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Velocity-driven steady Poiseuille validation (pimpleFoam).
//
// A uniform (plug) velocity of 0.0306 m/s is prescribed at the inlet.
// This corresponds to the Murray's-law-scaled mean flow rate for a 1 mm
// diameter artery derived from the Holdsworth CCA waveform (biphasic).
//
//   Q_mean_1mm = 6e-6  (0.5/3.   = 2.404e-8 ///sm15)
//   A          =   (0.        = 7.854e-7 m0005)
//   U_mean     = Q/A                 = 0.03061  0.0306 m/ss 
//
// pimpleFoam iterates toward the steady-state parabolic Hagen-Poiseuille
// profile without time-marching much faster than for large-Re cases.
//
// Expected steady-state:
//   U_avg    = 0.0306 m/s  (prescribed mean, plug flow)
//   U_center = 0.0612 m/s  (centreline peak of the Poiseuille parabola)
//   Re       = U_avg  2R / nu = 0.0306  0.001 / 3. 9.3  ()laminar 6 
//
//  9, the flow is well in the Stokes regime. Entry length:Re 
//    0.06 Entry Re   D = 0.06  9.3   0.56 mm001 
// The profile is virtually fully developed within the first cell.

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0.0306 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0.0306 0 0);
    }

    outlet
    {
        // zeroGradient: fully-developed outflow assumption.
        // For this near-Stokes steady-state case there is no backflow risk,
        // so zeroGradient is correct and more numerically robust than inletOutlet.
        type            zeroGradient;
    }

    wall
    {
        type            noSlip;
    }
}

