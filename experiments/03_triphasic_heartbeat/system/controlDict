FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Experiment 03 -- Triphasic Pulsatile Heartbeat in a 1 mm Straight Tube
//
// Solver: pimpleFoam (transient incompressible)
//
// Vessel: r = 0.5 mm, D = 1 mm, L = 10 mm
// Cardiac parameters:
//   T           = 0.857 s      (70 bpm)
//   Q_mean      = 1.656e-8 m3/s (SFA->1mm via Murray: 2.07e-6 * (0.5/2.5)^3)
//   U_mean      = 0.02109 m/s  (Q_mean / A = 1.656e-8 / 7.854e-7)
//   U_center_pk = 0.506 m/s    (2 * Q_peak / A, Q_norm_peak = 12)
//   U_center_min= -0.135 m/s   (flow reversal, Q_norm_min = -3.2)
//   Re_mean     = 6.4          (U_mean * D / nu = 0.02109 * 0.001 / 3.3e-6)
//   Re_peak     = 77           (U_mean_peak * D / nu)
//   Womersley   = 0.745        (quasi-Poiseuille, parabolic profile justified)
//
// TRIPHASIC: forward systolic peak, early-diastolic flow reversal, diastolic decay.
// Flow reversal inlet acts as outflow; outlet (zeroGradient) acts as inflow.
//
// Time step: dt = 0.0004 s → 2143 steps/cycle, 6428 total (3 cycles).
//   CFL_axial_mean = U_mean * dt / dx = 0.021 * 0.0004 / 0.00025 = 0.034  (< 1 ✓)
//   CFL_axial_peak = U_center_pk * dt / dx = 0.506 * 0.0004 / 0.00025 = 0.81 (< 1 ✓)
//   dt=0.0004 chosen (vs 0.0005) to keep CFL < 1 at peak systole for PISO stability.
//
// libs: required for codedFixedValue inlet BC (runtime C++ compilation).

application     pimpleFoam;

startFrom       startTime;
startTime       0;

stopAt          endTime;

// Run for 3 cardiac cycles: endTime = 3 × 0.857 = 2.571 s
endTime         2.571;

// deltaT = 0.0004 s → CFL_peak = 0.81 (< 1 ✓)
deltaT          0.0004;

writeControl    runTime;
writeInterval   0.0128;     // 2.571 / 0.0128 ≈ 201 snapshots over 3 cycles (~200)

purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

// Required for codedFixedValue (runtime C++ compilation of triphasic inlet BC)
libs ("libutilityFunctionObjects.so");

// ── Function objects: hemodynamic metrics ────────────────────────────────────
functions
{
    // ── Q(t): volumetric flow rate ────────────────────────────────────────
    // Written every time step (cheap scalar) for full Q(t) waveform resolution.
    // Note: during reversal phase inlet phi > 0 (outflow), outlet phi < 0.

    flowRateInlet
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        executeControl  timeStep;
        writeControl    timeStep;
        writeInterval   1;
        log             false;
        writeFields     false;
        regionType      patch;
        name            inlet;
        operation       sum;
        fields          (phi);
    }

    flowRateOutlet
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        executeControl  timeStep;
        writeControl    timeStep;
        writeInterval   1;
        log             false;
        writeFields     false;
        regionType      patch;
        name            outlet;
        operation       sum;
        fields          (phi);
    }

    // ── ΔP(t): pressure drop across the tube ─────────────────────────────
    // Kinematic pressure (p/rho). Multiply by rho=1060 for Pa.

    pAvgInlet
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        executeControl  timeStep;
        writeControl    timeStep;
        writeInterval   1;
        log             false;
        writeFields     false;
        regionType      patch;
        name            inlet;
        operation       areaAverage;
        fields          (p);
    }

    pAvgOutlet
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        executeControl  timeStep;
        writeControl    timeStep;
        writeInterval   1;
        log             false;
        writeFields     false;
        regionType      patch;
        name            outlet;
        operation       areaAverage;
        fields          (p);
    }

    // ── WSS field: wall shear stress vector on the wall patch ─────────────

    wallShearStress
    {
        type            wallShearStress;
        libs            ("libfieldFunctionObjects.so");
        executeControl  writeTime;
        writeControl    writeTime;
        log             false;
        patches         (wall);
    }

    // ── Time-averaged fields → TAWSS base ────────────────────────────────

    fieldAverage
    {
        type            fieldAverage;
        libs            ("libfieldFunctionObjects.so");
        executeControl  writeTime;
        writeControl    writeTime;
        log             false;
        fields
        (
            U
            {
                mean        on;
                prime2Mean  off;
                base        time;
            }
            p
            {
                mean        on;
                prime2Mean  off;
                base        time;
            }
            wallShearStress
            {
                mean        on;
                prime2Mean  off;
                base        time;
            }
        );
    }
}

