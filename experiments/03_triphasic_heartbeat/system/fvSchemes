FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Transient pulsatile schemes for pimpleFoam.
//
// CrankNicolson 0.9 for ddt: second-order temporal accuracy is important
// here because we are resolving the cardiac waveform in time. The blending
// coefficient 0.9 gives near-CN accuracy while avoiding the odd-even
// pressure oscillations of pure CN (coefficient = 1.0).
//
// linearUpwind for div: bounded second-order; well-suited to structured
// O-grid meshes and prevents spurious oscillations near the axis.

ddtSchemes
{
    default         CrankNicolson 0.9;
}

gradSchemes
{
    default         Gauss linear;
    grad(U)         Gauss linear;
}

divSchemes
{
    default         none;
    div(phi,U)      Gauss linearUpwind grad(U);
    div((nuEff*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

