FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Transient pulsatile schemes for pimpleFoam — 1 mm artery, Re_mean=6.4.
//
// Euler for ddt: unconditionally stable first-order time integration.
//
// Gauss linear for div: central-differencing, second-order accurate.
//   At Re_peak < 80 (very laminar flow) this scheme is stable and accurate.
//   No limiter needed.
//
// Gauss linear limited 0.5 for laplacian/snGrad: clips the non-orthogonality
//   correction to at most 50% of the face-normal gradient. Prevents
//   negative off-diagonal coefficients on O-grid corner cells.

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default         none;
    div(phi,U)      Gauss linear;
    div((nuEff*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear limited 0.5;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         limited 0.5;
}

