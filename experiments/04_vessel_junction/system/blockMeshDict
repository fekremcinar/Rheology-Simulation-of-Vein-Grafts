FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Experiment 04 -- Biphasic Pulsatile Flow Through a Sudden Expansion Junction
// Step expansion: r1 = 0.5 mm (inlet, D1 = 1 mm) --> r2 = 1.0 mm (outlet, D2 = 2 mm)
// r2/r1 = 2.0 > 3/2 -- above graft threshold (no graft, baseline case)
//
// Coordinate system:
//   x : flow direction
//   y : horizontal
//   z : vertical
//
// Geometry:
//   Inlet    (x = 0      to 0.01 m) : r1 = 0.0005 m  (L1 = 10 mm = 10 x D1)
//   Junction (x = 0.01 m)           : sudden step expansion, annular step-wall face
//   Outlet   (x = 0.01   to 0.03 m) : r2 = 0.0010 m  (L2 = 20 mm = 10 x D2)
//
// O-grid topology -- 14 hex blocks, 32 vertices:
//   Cross-section uses THREE concentric layers in the outlet, TWO in the inlet:
//     Layer 0 : inner square      half-width a = r1/2 = 0.00025 m
//     Layer 1 : r1 ring           corners at r1/sqrt(2) = 0.000354 m  (inlet wall; outlet internal)
//     Layer 2 : r2 ring           corners at r2/sqrt(2) = 0.000707 m  (outlet wall)
//
//   Inlet section (x = 0 to 0.01 m) : 5 blocks
//     1 centre block  (layer 0)
//     4 outer blocks  (layer 0 --> layer 1, wall = r1 cylinder)
//
//   Outlet section (x = 0.01 to 0.03 m) : 9 blocks
//     1 centre block  (layer 0)
//     4 inner blocks  (layer 0 --> layer 1, internal shear-layer interface)
//     4 outer blocks  (layer 1 --> layer 2, wall = r2 cylinder)
//
//   Connectivity at junction (x = 0.01 m):
//     Inlet centre end-face      <-> Outlet centre start-face       (internal)
//     Inlet outer block end-face <-> Outlet inner block start-face  (internal)
//     Outlet outer block k=0 faces --> step wall patch (annular, r1 to r2)
//
// Key dimensions:
//   a  = 0.00025  m   inner square half-width (= r1/2)
//   b  = 0.000354 m   r1/sqrt(2)  (r1 ring corner, 45 deg on r1 circle)
//   c  = 0.000707 m   r2/sqrt(2)  (r2 ring corner, 45 deg on r2 circle)
//   L1 = 0.01     m   inlet length
//   L  = 0.03     m   total length
//
// Mesh resolution:
//   Axial   : 40 cells (inlet, dx = 0.25 mm) / 40 cells (outlet, dx = 0.50 mm)
//   Core    : 12 x 12 cells (centre block)
//   Radial  :  8 cells per ring, grading 0.25 (4:1 toward outer wall)
//   Total   : approx. 57 000 cells

scale 1;

vertices
(
    // -- Inlet plane  x = 0 -------------------------------------------------
    // Inner square corners  (a = 0.00025 m)
    ( 0       0.00025  -0.00025 )  //  0  inner  +y -z
    ( 0       0.00025   0.00025 )  //  1  inner  +y +z
    ( 0      -0.00025   0.00025 )  //  2  inner  -y +z
    ( 0      -0.00025  -0.00025 )  //  3  inner  -y -z

    // r1-ring corners  (b = r1/sqrt(2) = 0.000354 m)
    ( 0       0.000354 -0.000354)  //  4  r1  315 deg  (+y -z)
    ( 0       0.000354  0.000354)  //  5  r1   45 deg  (+y +z)
    ( 0      -0.000354  0.000354)  //  6  r1  135 deg  (-y +z)
    ( 0      -0.000354 -0.000354)  //  7  r1  225 deg  (-y -z)

    // -- Junction plane  x = L1 = 0.01 m ------------------------------------
    // Inner square corners
    ( 0.01    0.00025  -0.00025 )  //  8  inner  +y -z
    ( 0.01    0.00025   0.00025 )  //  9  inner  +y +z
    ( 0.01   -0.00025   0.00025 )  // 10  inner  -y +z
    ( 0.01   -0.00025  -0.00025 )  // 11  inner  -y -z

    // r1-ring corners (inlet wall / outlet inner interface)
    ( 0.01    0.000354 -0.000354)  // 12  r1  315 deg
    ( 0.01    0.000354  0.000354)  // 13  r1   45 deg
    ( 0.01   -0.000354  0.000354)  // 14  r1  135 deg
    ( 0.01   -0.000354 -0.000354)  // 15  r1  225 deg

    // r2-ring corners (outer edge of step-wall annulus)
    ( 0.01    0.000707 -0.000707)  // 16  r2  315 deg
    ( 0.01    0.000707  0.000707)  // 17  r2   45 deg
    ( 0.01   -0.000707  0.000707)  // 18  r2  135 deg
    ( 0.01   -0.000707 -0.000707)  // 19  r2  225 deg

    // -- Outlet plane  x = L = 0.03 m ----------------------------------------
    // Inner square corners
    ( 0.03    0.00025  -0.00025 )  // 20  inner  +y -z
    ( 0.03    0.00025   0.00025 )  // 21  inner  +y +z
    ( 0.03   -0.00025   0.00025 )  // 22  inner  -y +z
    ( 0.03   -0.00025  -0.00025 )  // 23  inner  -y -z

    // r1-ring corners (internal block interface, not a wall)
    ( 0.03    0.000354 -0.000354)  // 24  r1  315 deg
    ( 0.03    0.000354  0.000354)  // 25  r1   45 deg
    ( 0.03   -0.000354  0.000354)  // 26  r1  135 deg
    ( 0.03   -0.000354 -0.000354)  // 27  r1  225 deg

    // r2-ring corners (outlet wall)
    ( 0.03    0.000707 -0.000707)  // 28  r2  315 deg
    ( 0.03    0.000707  0.000707)  // 29  r2   45 deg
    ( 0.03   -0.000707  0.000707)  // 30  r2  135 deg
    ( 0.03   -0.000707 -0.000707)  // 31  r2  225 deg
);

blocks
(
    // == Inlet section (x = 0 to 0.01 m) =====================================
    // 5 blocks, r1 = 0.0005 m, 40 axial cells (dx = 0.25 mm)

    // Centre block
    hex ( 3  0  1  2  11  8  9 10) (12 12 40) simpleGrading (1    1 1)

    // Outer blocks -- graded toward r1 wall (finer at r1 side, grading 0.25)
    hex ( 0  4  5  1   8 12 13  9) ( 8 12 40) simpleGrading (0.25 1 1)  // right
    hex ( 1  5  6  2   9 13 14 10) ( 8 12 40) simpleGrading (0.25 1 1)  // top
    hex ( 2  6  7  3  10 14 15 11) ( 8 12 40) simpleGrading (0.25 1 1)  // left
    hex ( 3  7  4  0  11 15 12  8) ( 8 12 40) simpleGrading (0.25 1 1)  // bottom

    // == Outlet section (x = 0.01 to 0.03 m) ==================================
    // 9 blocks, r2 = 0.001 m, 40 axial cells (dx = 0.50 mm)
    // Inner blocks share k=0 faces with inlet outer block k=Nk faces at x=0.01.
    // Outer blocks k=0 faces at x=0.01 form the annular step wall.

    // Centre block
    hex (11  8  9 10  23 20 21 22) (12 12 40) simpleGrading (1    1 1)

    // Inner blocks (inner square --> r1 ring) -- finer toward shear-layer at r1
    hex ( 8 12 13  9  20 24 25 21) ( 8 12 40) simpleGrading (0.25 1 1)  // right
    hex ( 9 13 14 10  21 25 26 22) ( 8 12 40) simpleGrading (0.25 1 1)  // top
    hex (10 14 15 11  22 26 27 23) ( 8 12 40) simpleGrading (0.25 1 1)  // left
    hex (11 15 12  8  23 27 24 20) ( 8 12 40) simpleGrading (0.25 1 1)  // bottom

    // Outer blocks (r1 ring --> r2 ring) -- graded toward r2 wall
    hex (12 16 17 13  24 28 29 25) ( 8 12 40) simpleGrading (0.25 1 1)  // right
    hex (13 17 18 14  25 29 30 26) ( 8 12 40) simpleGrading (0.25 1 1)  // top
    hex (14 18 19 15  26 30 31 27) ( 8 12 40) simpleGrading (0.25 1 1)  // left
    hex (15 19 16 12  27 31 28 24) ( 8 12 40) simpleGrading (0.25 1 1)  // bottom
);

// Arc edges -- enforce true circular cross-sections
edges
(
    // -- x = 0 (inlet plane): r1 arcs (r1 = 0.0005 m) -----------------------
    arc  4  5 ( 0      0.0005   0      )  // 315 -> 45  deg, midpoint at   0 deg (right)
    arc  5  6 ( 0      0        0.0005 )  //  45 -> 135 deg, midpoint at  90 deg (top)
    arc  6  7 ( 0     -0.0005   0      )  // 135 -> 225 deg, midpoint at 180 deg (left)
    arc  7  4 ( 0      0       -0.0005 )  // 225 -> 315 deg, midpoint at 270 deg (bottom)

    // -- x = 0.01 (junction plane): r1 arcs and r2 arcs ----------------------
    // r1 arcs (r1 = 0.0005 m)
    arc 12 13 ( 0.01   0.0005   0      )
    arc 13 14 ( 0.01   0        0.0005 )
    arc 14 15 ( 0.01  -0.0005   0      )
    arc 15 12 ( 0.01   0       -0.0005 )

    // r2 arcs (r2 = 0.001 m, outer edge of step wall)
    arc 16 17 ( 0.01   0.001    0      )
    arc 17 18 ( 0.01   0        0.001  )
    arc 18 19 ( 0.01  -0.001    0      )
    arc 19 16 ( 0.01   0       -0.001  )

    // -- x = 0.03 (outlet plane): r2 arcs (r2 = 0.001 m) --------------------
    arc 28 29 ( 0.03   0.001    0      )
    arc 29 30 ( 0.03   0        0.001  )
    arc 30 31 ( 0.03  -0.001    0      )
    arc 31 28 ( 0.03   0       -0.001  )
);

boundary
(
    // -- Inlet face (x = 0, outward normal = -x) ------------------------------
    inlet
    {
        type patch;
        faces
        (
            ( 3  2  1  0)   // centre
            ( 0  1  5  4)   // right outer
            ( 1  2  6  5)   // top outer
            ( 2  3  7  6)   // left outer
            ( 3  0  4  7)   // bottom outer
        );
    }

    // -- Outlet face (x = 0.03, outward normal = +x) --------------------------
    outlet
    {
        type patch;
        faces
        (
            (23 20 21 22)   // centre
            (20 24 25 21)   // right inner
            (21 25 26 22)   // top inner
            (22 26 27 23)   // left inner
            (23 27 24 20)   // bottom inner
            (24 28 29 25)   // right outer
            (25 29 30 26)   // top outer
            (26 30 31 27)   // left outer
            (27 31 28 24)   // bottom outer
        );
    }

    // -- No-slip walls --------------------------------------------------------
    // Three wall zones merged into one "wall" patch:
    //   (a) Upstream cylinder (r1 = 0.0005 m), x = 0 to 0.01 m
    //   (b) Annular step face, x = 0.01 m, r1 to r2 (outward normal = -x)
    //   (c) Downstream cylinder (r2 = 0.001 m), x = 0.01 to 0.03 m
    wall
    {
        type wall;
        faces
        (
            // (a) Upstream r1 cylinder wall -- i=Ni faces of inlet outer blocks
            ( 4  5 13 12)   // right arc, x 0 -> 0.01
            ( 5  6 14 13)   // top  arc
            ( 6  7 15 14)   // left arc
            ( 7  4 12 15)   // bottom arc

            // (b) Annular step wall -- k=0 faces of outlet outer blocks (at x=0.01)
            (12 13 17 16)   // right sector
            (13 14 18 17)   // top  sector
            (14 15 19 18)   // left sector
            (15 12 16 19)   // bottom sector

            // (c) Downstream r2 cylinder wall -- i=Ni faces of outlet outer blocks
            (16 17 29 28)   // right arc, x 0.01 -> 0.03
            (17 18 30 29)   // top  arc
            (18 19 31 30)   // left arc
            (19 16 28 31)   // bottom arc
        );
    }
);

