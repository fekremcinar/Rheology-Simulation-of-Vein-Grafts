            const vectorField& Cf = patch().Cf();
            forAll(Cf, faceI)
            {
                const scalar y   = Cf[faceI].y();
                const scalar z   = Cf[faceI].z();
                const scalar r   = Foam::sqrt(y*y + z*z);
                const scalar eta = Foam::min(r / R_, scalar(1.0));

                // Radial index in uniform lookup table (eta in [0,1])
                const scalar idx_f = eta * scalar(N_rad - 1);
                const int    k     = Foam::min(int(idx_f), N_rad - 2);
                const scalar frac  = idx_f - scalar(k);

                // DC component: Poiseuille  u0(r) = 2*U0*(1 - eta^2)
                scalar Uf = 2.0 * U0_ * (1.0 - eta*eta);

                // Womersley harmonics
                for (int n = 0; n < N_harm; n++)
                {
                    const scalar omega_n = scalar(n + 1) * omega0;
                    const scalar A = U_A[n];
                    const scalar B = U_B[n];

                    // Linear radial interpolation of shape function
                    const scalar Wr_e = Wr[n][k]*(1.0 - frac) + Wr[n][k+1]*frac;
                    const scalar Wi_e = Wi[n][k]*(1.0 - frac) + Wi[n][k+1]*frac;

                    // Re[ (A+iB)(Wr+iWi) e^(i*n*omega*t) ]
                    const scalar cos_t = Foam::cos(omega_n * t_);
                    const scalar sin_t = Foam::sin(omega_n * t_);
                    Uf += (A*Wr_e - B*Wi_e)*cos_t - (A*Wi_e + B*Wr_e)*sin_t;
                }

                operator[](faceI) = vector(Uf, 0.0, 0.0);
            }
